# =========================================================================
# COMBINED NGINX CONFIGURATION FOR HOSTINGER VPS
# Domain Setup:
#   1. Main Client Site : https://blackpanther-batteries.com (and www)
#   2. Admin Dashboard  : https://admin.blackpanther-batteries.com
#   3. API & Uploads    : https://api.blackpanther-batteries.com
# =========================================================================

# -------------------------------------------------------------------------
# 1. CLIENT WEBSITE (blackpanther-batteries.com & www)
# -------------------------------------------------------------------------
server {
    listen 80;
    server_name blackpanther-batteries.com www.blackpanther-batteries.com;

    root /var/www/blackpanther/client/dist;
    index index.html;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml image/svg+xml;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|webp|woff|woff2|ttf|eot)$ {
        expires 30d;
        add_header Cache-Control "public, no-transform";
    }
}

# -------------------------------------------------------------------------
# 2. ADMIN DASHBOARD (admin.blackpanther-batteries.com)
# -------------------------------------------------------------------------
server {
    listen 80;
    server_name admin.blackpanther-batteries.com;

    root /var/www/blackpanther/admin/dist;
    index index.html;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml image/svg+xml;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|webp|woff|woff2|ttf|eot)$ {
        expires 30d;
        add_header Cache-Control "public, no-transform";
    }
}

# -------------------------------------------------------------------------
# 3. BACKEND API & UPLOADS MEDIA (api.blackpanther-batteries.com)
# -------------------------------------------------------------------------
server {
    listen 80;
    server_name api.blackpanther-batteries.com;

    client_max_body_size 20M;

    # Node.js Express Reverse Proxy (Port 3000)
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Uploaded Images with CORS headers for main site & admin panel
    location /uploads/ {
        proxy_pass http://127.0.0.1:3000/uploads/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;

        add_header 'Access-Control-Allow-Origin' '*' always;
        add_header 'Access-Control-Allow-Methods' 'GET, OPTIONS' always;
        expires 30d;
        add_header Cache-Control "public, no-transform";
    }
}
